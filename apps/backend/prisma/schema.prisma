generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  sales
  owner
}

enum TaskType {
  proposal
  follow_up
  meeting_request
  document_submission
  preventive_check
  other
}

enum TaskStatus {
  on_track
  near_deadline
  overdue
  extended
  completed
}

enum ExtensionStatus {
  pending
  approved
  rejected
}

enum CoachingStatus {
  open
  closed
}

model User {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  password_hash String
  role          Role     @default(sales)
  created_at    DateTime @default(now())

  tasks            Task[]
  daily_activities DailyActivity[]
  weekly_summaries WeeklySummary[]
  coaching_requests CoachingRequest[]
  approved_extensions ExtensionRequest[] @relation("ApprovedBy")
}

model Task {
  id              String     @id @default(uuid())
  user_id         String
  account_name    String
  task_type       TaskType
  title           String
  deadline        DateTime
  status          TaskStatus @default(on_track)
  extension_count Int        @default(0)
  created_at      DateTime   @default(now())
  completed_at    DateTime?

  user       User               @relation(fields: [user_id], references: [id])
  extensions ExtensionRequest[]
}

model ExtensionRequest {
  id                 String          @id @default(uuid())
  task_id            String
  reason             String
  reason_detail      String?
  requested_deadline DateTime
  status             ExtensionStatus @default(pending)
  requested_at       DateTime        @default(now())
  approved_by        String?
  approved_at        DateTime?

  task     Task  @relation(fields: [task_id], references: [id])
  approver User? @relation("ApprovedBy", fields: [approved_by], references: [id])
}

model DailyActivity {
  id                       String   @id @default(uuid())
  user_id                  String
  date                     DateTime @default(now())
  account_progress         Int      @default(0)
  stakeholder_interaction  Int      @default(0)
  meeting_requested        Int      @default(0)
  follow_up_done           Int      @default(0)
  preventive_shared        Int      @default(0)
  reflection_text          String

  user User @relation(fields: [user_id], references: [id])

  @@unique([user_id, date])
}

model WeeklySummary {
  id                    String   @id @default(uuid())
  user_id               String
  week_start            DateTime
  sla_on_time_percentage Float   @default(0)
  meeting_count         Int      @default(0)
  overdue_count         Int      @default(0)
  extension_count       Int      @default(0)
  stagnant_account_count Int     @default(0)
  preventive_count      Int      @default(0)
  flags                 Json     @default("[]")
  created_at            DateTime @default(now())

  user User @relation(fields: [user_id], references: [id])

  @@unique([user_id, week_start])
}

model CoachingRequest {
  id         String         @id @default(uuid())
  user_id    String
  reason     String
  status     CoachingStatus @default(open)
  created_at DateTime       @default(now())

  user User @relation(fields: [user_id], references: [id])
}
